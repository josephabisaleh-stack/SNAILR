<%= turbo_stream_from @chat %>

<% if @objective.status == "in_creation" %>
  <% content_for :head do %>
    <style>
      header { display: none; }
      #main-content { padding: 0; margin: 0; }
    </style>
  <% end %>

  <div class="creation-page">
    <div class="creation-container">

      <div class="brand-section">
        <div class="brand-wordmark">Snail<span class="brand-r">-R</span></div>
      </div>

      <div class="mascot-wrapper">
        <div class="mascot-ring">
          <div class="mascot-circle">
            <span class="mascot-emoji">🐌</span>
          </div>
        </div>
        <div class="mascot-glow"></div>
      </div>

      <div class="creation-hero">
        <h2 class="hero-headline">
          <% if @objective.title.present? %>
            <%= @objective.title %>
          <% else %>
            Let's build your objective.
          <% end %>
        </h2>
        <p class="hero-description">
          <% if @chat.messages.where(role: "assistant").any? %>
            You can refine the steps or confirm to get started.
          <% else %>
            Describe your goal and SnailR will suggest concrete steps.
          <% end %>
        </p>
      </div>

      <div class="creation-chat" id="messages">
        <% @chat.messages.each do |message| %>
          <%= render "messages/message", message: message %>
        <% end %>
      </div>

      <% waiting_for_llm = @chat.messages.order(:created_at).last&.role == "user" %>
      <div id="llm-loading" class="chat-bubble chat-assistant" style="<%= waiting_for_llm ? '' : 'display:none;' %>">
        <span class="llm-spinner">🌀</span>
      </div>

      <div class="creation-form">
        <%= simple_form_for [@chat, @message] do |f| %>
          <% has_assistant_reply = @chat.messages.where(role: "assistant").any? %>
          <%= f.input :content,
                label: false,
                required: true,
                placeholder: has_assistant_reply ? "Refine or adjust the steps..." : "I would like to learn to code...",
                input_html: { class: "creation-input" } %>
          <%= f.button :submit, 'Ask Snail-R', class: 'btn-cta btn-signup' %>
        <% end %>
      </div>

      <% if @chat.messages.where(role: "assistant").any? %>
        <div class="creation-confirm">
          <%= button_to "Confirm & Get Started", confirm_objective_path(@objective), method: :patch, class: "btn-cta btn-confirm" %>
        </div>
      <% end %>

    </div>
  </div>
  <script>
    function scrollToBottom() { window.scrollTo(0, document.body.scrollHeight); }
    document.addEventListener("turbo:load", scrollToBottom);
    document.addEventListener("turbo:before-stream-render", function() {
      document.getElementById("llm-loading").style.display = "none";
      setTimeout(scrollToBottom, 50);
    });
    document.addEventListener("turbo:load", function() {
      var form = document.querySelector(".creation-form form");
      if (form) {
        form.addEventListener("submit", function() {
          document.getElementById("llm-loading").style.display = "";
          setTimeout(scrollToBottom, 50);
        });
      }
    });
  </script>
  <style>
    @keyframes spin { to { transform: rotate(360deg); } }
    .llm-spinner { display: inline-block; animation: spin 1s linear infinite; font-size: 2rem; }
  </style>
<% else %>
  <%= render "in_progress" %>
<% end %>
