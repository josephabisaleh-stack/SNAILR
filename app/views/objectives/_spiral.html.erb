<div id="spiral-section">
  <% if steps.empty? %>
    <div class="spiral-loading">
      <div class="loading-rings">
        <div class="loading-ring"></div>
        <div class="loading-ring"></div>
        <div class="loading-ring"></div>
      </div>
      <p class="loading-text">Crafting your path...</p>
    </div>
  <% else %>
  <div id="spiral-container"
       data-controller="spiral"
       data-steps="<%= steps.map { |s| { id: s.id, position: s.position, title: s.title, done: s.done, xp_reward: s.xp_reward } }.to_json %>">
    <canvas id="spiral-canvas"></canvas>
  </div>

  <% done_count = steps.count(&:done) %>
  <% progress = steps.any? ? (done_count * 100.0 / steps.size).round : 0 %>
  <div class="progress-bar-wrapper" id="progress-bar-wrapper">
    <div class="progress-track">
      <div class="progress-fill" style="width: <%= progress %>%"></div>
    </div>
    <span class="progress-label"><%= done_count %>/<%= steps.size %> steps</span>
  </div>

  <% steps.each do |step| %>
    <div class="modal fade" id="stepModal-<%= step.id %>" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-corner"><%= step.position %></div>
          <div class="modal-header">
            <div class="modal-title-wrapper flex-column">
              <span class="modal-index">Step <%= step.position %></span>
              <span class="modal-title"><%= step.title %></span>
            </div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <div class="fib-status">
              <% if step.done %>
                <span class="status-done">&#10003; Completed</span>
              <% else %>
                <span class="status-pending">&#9675; In progress</span>
              <% end %>
              <div class="fib-ratio">&#10022; <strong><%= step.xp_reward %> XP</strong> reward</div>
            </div>
            <div class="step-details mt-3">
              <div class="step-detail-item">
                <div class="step-detail-label">Goal</div>
                <div class="step-detail-value"><%= step.goal %></div>
              </div>
              <div class="step-detail-item mt-2">
                <div class="step-detail-label">Obstacle</div>
                <div class="step-detail-value"><%= step.obstacle %></div>
              </div>
              <div class="step-detail-item mt-2">
                <div class="step-detail-label">Quick Fix</div>
                <div class="step-detail-value"><%= step.quick_fix %></div>
              </div>
            </div>
          </div>
          <div class="modal-footer justify-content-between">
            <button type="button" class="btn-gold" data-bs-dismiss="modal">Close</button>
            <% unless step.done %>
              <button type="button" class="btn-complete" data-step-id="<%= step.id %>">
                <i class="fa-solid fa-check"></i> Mark as completed
              </button>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <script>
    document.querySelectorAll('.btn-complete').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var stepId = this.dataset.stepId;
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-check"></i> Completed';
        btn.classList.add('btn-completed');

        fetch('/steps/' + stepId + '/mark_step_as_done', {
          method: 'PATCH',
          headers: {
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
            'Accept': 'application/json'
          }
        }).then(function(r) { return r.json(); }).then(function(data) {
          var fill = document.querySelector('.progress-fill');
          var label = document.querySelector('.progress-label');
          if (fill) fill.style.width = data.progress + '%';
          if (label) label.textContent = data.done_count + '/' + data.total_count + ' steps';

          var modal = btn.closest('.modal');
          if (modal) {
            var status = modal.querySelector('.fib-status');
            if (status) {
              var span = status.querySelector('.status-pending');
              if (span) { span.className = 'status-done'; span.innerHTML = '&#10003; Completed'; }
            }
          }
        });
      });
    });
  </script>
  <% end %>
</div>
