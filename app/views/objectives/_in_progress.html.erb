<script>
// Stars
const sf = document.getElementById('starfield');
for(let i=0;i<180;i++){
  const s=document.createElement('div');
  const sz=Math.random()*2.5+0.5;
  s.className='star';
  s.style.cssText=`width:${sz}px;height:${sz}px;top:${Math.random()*100}%;left:${Math.random()*100}%;--dur:${2+Math.random()*4}s;--delay:${-Math.random()*4}s;--base-op:${0.1+Math.random()*0.4};opacity:var(--base-op)`;
  sf.appendChild(s);
}

// Cursor
const cursor=document.getElementById('cursor');
document.addEventListener('mousemove',e=>{
  cursor.style.left=(e.clientX-6)+'px';
  cursor.style.top=(e.clientY-6)+'px';
});

// Tooltip
const tooltip=document.getElementById('tooltip');
const ttTitle=document.getElementById('tt-title');
const ttBody=document.getElementById('tt-body');
const stageData={
  1:{title:'Initiation — The Seed',body:'First awakening. The journey begins here.'},
  2:{title:'Learning',body:'Cultivating knowledge through practice.'},
  3:{title:'Expansion',body:'Expanding horizons, pushing limits.'},
  4:{title:'Mastery',body:'Excellence forged through experience.'},
  5:{title:'Achievement',body:'Transcendence. The summit is reached.'}
};
document.querySelectorAll('.node').forEach(n=>{
  n.addEventListener('mouseenter',()=>{
    const d=stageData[n.dataset.stage];
    ttTitle.textContent=d.title; ttBody.textContent=d.body;
    tooltip.classList.add('show');
  });
  n.addEventListener('mouseleave',()=>tooltip.classList.remove('show'));
  n.addEventListener('mousemove',e=>{
    tooltip.style.left=(e.clientX+18)+'px';
    tooltip.style.top=(e.clientY-10)+'px';
  });
});

// Labels
const labelThresholds={'label-1':0.05,'label-2':0.22,'label-3':0.38,'label-4':0.54,'label-5':0.70};
const labelHideAt={'label-1':0.18,'label-2':0.34,'label-3':0.50,'label-4':0.66,'label-5':0.84};
const dots=document.querySelectorAll('.dot');

function onScroll(){
  const p=window.scrollY/(document.body.scrollHeight-window.innerHeight);
  for(const[id,t]of Object.entries(labelThresholds)){
    const el=document.getElementById(id);
    el.classList.toggle('visible',p>=t&&p<labelHideAt[id]);
  }
  let a=1;
  if(p>=0.70)a=5; else if(p>=0.54)a=4; else if(p>=0.38)a=3; else if(p>=0.22)a=2;
  dots.forEach(d=>d.classList.toggle('active',+d.dataset.stage===a));
}
window.addEventListener('scroll',onScroll,{passive:true});
onScroll();

// Dot clicks
const getMax=()=>document.body.scrollHeight-window.innerHeight;
const targets={1:0.05,2:0.22,3:0.38,4:0.54,5:0.70};
dots.forEach(d=>d.addEventListener('click',()=>{
  window.scrollTo({top:targets[+d.dataset.stage]*getMax(),behavior:'smooth'});
}));
</script>
