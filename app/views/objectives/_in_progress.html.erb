<style>
    :root {
      --gold: #c9a84c;
      --gold-light: #e8d08a;
      --cream: #f5f0e8;
      --ink: #1a1410;
      --ink-mid: #2e2418;
      --ink-light: #5c4a2a;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--ink);
      font-family: 'Cormorant Garamond', serif;
      color: var(--cream);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.08'/%3E%3C/svg%3E");
      opacity: 0.4;
      pointer-events: none;
      z-index: 0;
    }

    header {
      position: fixed;
      top: 2rem;
      text-align: center;
      z-index: 10;
    }

    header h1 {
      font-family: 'Syncopate', sans-serif;
      font-size: clamp(0.65rem, 1.5vw, 0.9rem);
      font-weight: 400;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      opacity: 0.85;
    }

    header p {
      font-size: 0.85rem;
      font-style: italic;
      color: var(--cream);
      opacity: 0.45;
      margin-top: 0.3rem;
      letter-spacing: 0.05em;
    }

    #spiral-container {
      position: relative;
      z-index: 2;
      width: min(90vw, 90vh);
      height: min(90vw, 90vh);
    }

    canvas#spiral-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .fib-point {
      position: absolute;
      transform: translate(-50%, -50%);
      cursor: pointer;
      z-index: 5;
    }

    .fib-point .point-ring {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 1.5px solid var(--gold);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      transition: transform 0.25s ease;
      background: rgba(201, 168, 76, 0.08);
      backdrop-filter: blur(2px);
    }

    .fib-point .point-ring::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--gold);
      transition: transform 0.25s ease, opacity 0.25s ease;
    }

    .fib-point .point-ring::after {
      content: '';
      position: absolute;
      inset: -6px;
      border-radius: 50%;
      border: 1px solid rgba(201, 168, 76, 0.2);
      transition: transform 0.4s ease, opacity 0.4s ease;
      opacity: 0;
    }

    .fib-point:hover .point-ring {
      transform: scale(1.4);
      background: rgba(201, 168, 76, 0.2);
    }

    .fib-point:hover .point-ring::before { transform: scale(1.3); }

    .fib-point:hover .point-ring::after {
      opacity: 1;
      transform: scale(1.3);
    }

    @keyframes pulse-ring {
      0%   { transform: scale(1);   opacity: 0.6; }
      70%  { transform: scale(2.2); opacity: 0; }
      100% { transform: scale(1);   opacity: 0; }
    }

    .fib-point.highlight .point-ring::after {
      opacity: 1;
      animation: pulse-ring 2s ease-out infinite;
    }

    .fib-point .point-label {
      position: absolute;
      top: -22px;
      left: 50%;
      transform: translateX(-50%);
      font-family: 'Syncopate', sans-serif;
      font-size: 0.45rem;
      letter-spacing: 0.1em;
      color: var(--gold-light);
      white-space: nowrap;
      opacity: 0;
      transition: opacity 0.2s;
      pointer-events: none;
    }

    .fib-point:hover .point-label { opacity: 1; }

    .modal-content {
      background: var(--ink-mid);
      border: 1px solid rgba(201, 168, 76, 0.25);
      border-radius: 0;
      color: var(--cream);
      box-shadow: 0 30px 80px rgba(0,0,0,0.8), inset 0 0 60px rgba(201,168,76,0.03);
      position: relative;
      overflow: hidden;
    }

    .modal-content::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--gold), transparent);
    }

    .modal-header {
      border-bottom: 1px solid rgba(201, 168, 76, 0.15);
      padding: 1.8rem 2rem 1.2rem;
      align-items: flex-start;
    }

    .modal-title-wrapper {
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }

    .modal-index {
      font-family: 'Syncopate', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.3em;
      color: var(--gold);
      opacity: 0.7;
      text-transform: uppercase;
    }

    .modal-title {
      font-family: 'Syncopate', sans-serif;
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      color: var(--gold-light);
      line-height: 1.3;
    }

    .modal-body { padding: 1.8rem 2rem; }

    .fib-number-display {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(3rem, 8vw, 5.5rem);
      font-weight: 300;
      color: var(--cream);
      line-height: 1;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
    }

    .fib-number-display span { color: var(--gold); font-style: italic; }

    .fib-formula {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 1rem;
      font-style: italic;
      color: rgba(245, 240, 232, 0.5);
      margin-bottom: 1.5rem;
      padding: 0.8rem 1rem;
      border-left: 2px solid rgba(201,168,76,0.3);
      background: rgba(201,168,76,0.04);
    }

    .fib-formula .val { color: var(--gold-light); font-style: normal; font-weight: 400; }

    .fib-fact {
      font-size: 1rem;
      line-height: 1.75;
      color: rgba(245, 240, 232, 0.7);
      letter-spacing: 0.01em;
    }

    .fib-ratio {
      margin-top: 1.2rem;
      padding: 0.7rem 1rem;
      background: rgba(201,168,76,0.06);
      border: 1px solid rgba(201,168,76,0.12);
      font-size: 0.85rem;
      color: rgba(245,240,232,0.5);
      letter-spacing: 0.05em;
    }

    .fib-ratio strong { color: var(--gold); font-weight: 400; }

    .modal-footer {
      border-top: 1px solid rgba(201, 168, 76, 0.12);
      padding: 1rem 2rem 1.5rem;
    }

    .btn-close { filter: invert(1); opacity: 0.4; transition: opacity 0.2s; }
    .btn-close:hover { opacity: 0.9; }

    .btn-gold {
      background: transparent;
      border: 1px solid rgba(201,168,76,0.5);
      color: var(--gold-light);
      font-family: 'Syncopate', sans-serif;
      font-size: 0.55rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      padding: 0.6rem 1.6rem;
      border-radius: 0;
      transition: background 0.2s, color 0.2s;
    }

    .btn-gold:hover { background: rgba(201,168,76,0.15); color: var(--cream); }

    .modal-corner {
      position: absolute;
      bottom: 1rem; right: 1.2rem;
      font-size: 3.5rem;
      font-family: 'Syncopate', sans-serif;
      color: rgba(201,168,76,0.06);
      font-weight: 700;
      pointer-events: none;
      line-height: 1;
    }

    .modal.fade .modal-dialog {
      transform: translateY(20px) scale(0.97);
      transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), opacity 0.35s;
    }
    .modal.show .modal-dialog { transform: translateY(0) scale(1); }

    footer {
      position: fixed;
      bottom: 1.5rem;
      font-size: 0.72rem;
      font-style: italic;
      color: rgba(245,240,232,0.2);
      letter-spacing: 0.1em;
      z-index: 10;
    }
  </style>
</head>
<body>

<header>
  <h1>Fibonacci Spiral</h1>
  <p>Click any point to explore the sequence</p>
</header>

<div id="spiral-container">
  <canvas id="spiral-canvas"></canvas>
</div>

<div class="modal fade" id="fibModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-corner" id="modal-corner-num"></div>
      <div class="modal-header">
        <div class="modal-title-wrapper flex-column">
          <span class="modal-index" id="modal-index-label"></span>
          <span class="modal-title" id="modal-title-text"></span>
        </div>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="fib-status" id="modal-fib-status"></div>
      </div>
      <div class="modal-footer justify-content-start">
        <button type="button" class="btn-gold" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<div id="steps-data" data-steps="<%= @steps.map { |s| { title: s.title, done: s.done, xp_reward: s.xp_reward } }.to_json %>"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
<script>
  // ─── Injected from Ruby @steps ─────────────────────────────────────────────
  // Each object: { title, done, xp_reward }
  const steps = JSON.parse(document.getElementById('steps-data').dataset.steps);
  // ───────────────────────────────────────────────────────────────────────────

  const PHI = (1 + Math.sqrt(5)) / 2;
  const totalPoints = steps.length;

  // Build Fibonacci numbers to match the number of steps
  const fibNumbers = [];
  let a = 0, b = 1;
  for (let i = 0; i < totalPoints; i++) {
    fibNumbers.push(a);
    [a, b] = [b, a + b];
  }

  // Enrich steps with their Fibonacci index and computed ratio
  const fibData = steps.map((step, i) => ({
    index: i,
    n: fibNumbers[i],
    title: step.title,
    done: step.done,
    xp_reward: step.xp_reward,
    ratio: i > 0 && fibNumbers[i - 1] > 0
      ? (fibNumbers[i] / fibNumbers[i - 1]).toFixed(6)
      : '—'
  }));

  // ─── Canvas / Spiral ───────────────────────────────────────────────────────
  const container = document.getElementById('spiral-container');
  const canvas = document.getElementById('spiral-canvas');
  const W = container.offsetWidth, H = container.offsetHeight;
  canvas.width = W; canvas.height = H;
  const ctx = canvas.getContext('2d');
  const cx = W / 2, cy = H / 2;
  const maxR = Math.min(W, H) * 0.47;
  const turns = 5;
  const steps_count = 2000;

  const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, W * 0.5);
  grd.addColorStop(0, 'rgba(201,168,76,0.06)');
  grd.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = grd;
  ctx.fillRect(0, 0, W, H);

  const drawSpiral = (scale, opacity, lineWidth) => {
    ctx.beginPath();
    for (let i = 0; i <= steps_count; i++) {
      const t = (i / steps_count) * turns * 2 * Math.PI;
      const r = maxR * scale * Math.exp(-0.17 * (turns * 2 * Math.PI - t));
      const x = cx + r * Math.cos(t);
      const y = cy + r * Math.sin(t);
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.strokeStyle = `rgba(201,168,76,${opacity})`;
    ctx.lineWidth = lineWidth;
    ctx.stroke();
  };

  drawSpiral(1, 0.18, 1.2);
  drawSpiral(0.85, 0.05, 0.6);

  // ─── Arc-length sampling for point placement ──────────────────────────────
  const pathSamples = [];
  for (let i = 0; i <= steps_count; i++) {
    const t = (i / steps_count) * turns * 2 * Math.PI;
    const r = maxR * Math.exp(-0.17 * (turns * 2 * Math.PI - t));
    pathSamples.push({ x: cx + r * Math.cos(t), y: cy + r * Math.sin(t) });
  }

  const cumLen = [0];
  for (let i = 1; i < pathSamples.length; i++) {
    const dx = pathSamples[i].x - pathSamples[i - 1].x;
    const dy = pathSamples[i].y - pathSamples[i - 1].y;
    cumLen.push(cumLen[i - 1] + Math.sqrt(dx * dx + dy * dy));
  }
  const totalLen = cumLen[cumLen.length - 1];

  // ─── Render one dot per step ───────────────────────────────────────────────
  const modal = new bootstrap.Modal(document.getElementById('fibModal'));

  fibData.forEach((d, i) => {
    const target = totalPoints > 1
      ? (i / (totalPoints - 1)) * totalLen
      : totalLen / 2;

    let lo = 0, hi = cumLen.length - 1;
    while (lo < hi - 1) {
      const mid = Math.floor((lo + hi) / 2);
      cumLen[mid] < target ? lo = mid : hi = mid;
    }
    const { x, y } = pathSamples[hi];

    const dot = document.createElement('div');
    dot.className = 'fib-point' + (i === 0 ? ' highlight' : '') + (d.done ? ' done' : '');
    dot.style.left = x + 'px';
    dot.style.top = y + 'px';
    dot.innerHTML = `
      <div class="point-ring"></div>
      <div class="point-label">${d.title}</div>
    `;

    dot.addEventListener('click', () => {
    const d = fibData[i];

    document.getElementById('modal-title-text').textContent = d.title;
    document.getElementById('modal-index-label').textContent = `Step ${i + 1}`;
    document.getElementById('modal-corner-num').textContent = i + 1;

    document.getElementById('modal-fib-status').innerHTML =
      d.xp_reward != null
        ? `${d.done ? `<span class="status-done">✓ Completed</span>` : `<span class="status-pending">○ In progress</span>`}
           <div class="fib-ratio">✦ <strong>${d.xp_reward} XP</strong> reward</div>`
        : `${d.done ? `<span class="status-done">✓ Completed</span>` : `<span class="status-pending">○ In progress</span>`}
           <div class="fib-ratio">No XP reward</div>`;

    modal.show();
    });

    container.appendChild(dot);
  });
</script>
