<% content_for :head do %>
  <style>
    header { display: none; }
    #main-content { padding: 0; margin: 0; }
  </style>
<% end %>

<div class="creation-page">
  <div class="creation-container">

    <div class="brand-section">
      <div class="brand-wordmark">Snail<span class="brand-r">-R</span></div>
    </div>

    <div class="mascot-wrapper">
      <div class="mascot-ring">
        <div class="mascot-circle">
          <span class="mascot-emoji">🐌</span>
        </div>
      </div>
      <div class="mascot-glow"></div>
    </div>

    <div class="creation-hero">
      <h2 class="hero-headline">Slow down, change your life !</h2>
    </div>

    <div class="creation-form">
      <%= form_with url: chats_path, method: :post do |f| %>
        <div class="snail-input-box">
          <%= f.text_field :content, placeholder: "What is my new challenge...", required: true, class: "creation-input snail-input-field", id: "chat-input-new" %>
          <!-- <span class="snail-walker" id="snail-new">🐌</span> -->
          <%= f.submit "🥗", class: "snail-submit-btn" %>
        </div>
      <% end %>
    </div>

  </div>
</div>

<style>
  .snail-input-box {
    position: relative;
    display: flex;
    align-items: center;
    border-radius: 999px;
    border: 1.5px solid rgba(0, 0, 0, 0.10);
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(8px);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    margin-bottom: 2.5rem;
    padding-right: 0.4rem;
    box-shadow: 0 4px 20px rgba(34, 85, 51, 0.15);
  }
  .snail-input-box:focus-within {
    border-color: rgba(34, 85, 51, 0.30);
    box-shadow: 0 4px 28px rgba(34, 85, 51, 0.30);
  }
  .snail-input-field {
    flex: 1;
    padding: 1rem 1.25rem;
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    outline: none !important;
    font-size: 0.95rem;
    position: relative;
    z-index: 2;
    border-radius: 999px;
  }
  .snail-submit-btn {
    flex-shrink: 0;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    border: none;
    background: #1a1a1a;
    color: #fff;
    font-size: 1.2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, transform 0.1s ease;
    z-index: 3;
    position: relative;
    filter: grayscale(100%) brightness(1.8) contrast(1.2);
  }
  .snail-submit-btn:hover {
    background: #333;
    transform: scale(1.05);
  }
  .snail-submit-btn:active {
    transform: scale(0.95);

}
  /* .snail-walker {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%) scaleX(-1);
    font-size: 1.8rem;
    pointer-events: none;
    z-index: 1;
    transition: opacity 0.2s;
  } */
</style>

