<% content_for :head do %>
  <style>
    header { display: none; }
    #main-content { padding: 0; margin: 0; }
  </style>
<% end %>

<div class="creation-page">
  <div class="creation-container">

    <div class="brand-section">
      <div class="brand-wordmark">Snail<span class="brand-r">-R</span></div>
    </div>

    <div class="mascot-wrapper">
      <div class="mascot-ring">
        <div class="mascot-circle">
          <span class="mascot-emoji">🐌</span>
        </div>
      </div>
      <div class="mascot-glow"></div>
    </div>

    <div class="creation-hero">
      <h2 class="hero-headline">Slow down, change your life !</h2>
    </div>

    <div class="creation-form">
      <%= form_with url: chats_path, method: :post do |f| %>
        <div class="snail-input-box">
          <%= f.text_field :content, placeholder: "I would like to learn to code...", required: true, class: "creation-input snail-input-field", id: "chat-input-new" %>
          <span class="snail-walker" id="snail-new">🐌</span>
          <button type="button" class="voice-btn" id="voice-btn" title="Dictate your objective">
            <i class="fa-solid fa-microphone"></i>
          </button>
        </div>
      <% end %>
    </div>

  </div>
</div>

<style>
  .snail-input-box {
    position: relative;
    display: flex;
    align-items: center;
    border-radius: 999px;
    border: 1.5px solid rgba(0, 0, 0, 0.10);
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(8px);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    margin-bottom: 2.5rem;
    padding-right: 0.4rem;
    box-shadow: 0 4px 20px rgba(34, 85, 51, 0.15);
  }
  .snail-input-box:focus-within {
    border-color: rgba(34, 85, 51, 0.30);
    box-shadow: 0 4px 28px rgba(34, 85, 51, 0.30);
  }
  .snail-input-field {
    width: 100%;
    padding: 1rem 3rem 1rem 1.25rem;
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
    outline: none !important;
    font-size: 0.95rem;
    position: relative;
    z-index: 2;
    border-radius: 999px;
  }
  .snail-submit-btn {
    flex-shrink: 0;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    border: none;
    background: #1a1a1a;
    color: #fff;
    font-size: 1.2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, transform 0.1s ease;
    z-index: 3;
    position: relative;
    filter: grayscale(100%) brightness(1.8) contrast(1.2);
  }
  .voice-btn {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    color: #A8A49E;
    padding: 6px 8px;
    border-radius: 50%;
    transition: color 0.2s ease, background 0.2s ease;
  }
  .voice-btn:hover {
    color: #1C1C1A;
    background: rgba(0, 0, 0, 0.05);
  }
  .voice-btn.recording {
    color: #E53935;
    animation: pulse-mic 1.2s ease-in-out infinite;
  }
  @keyframes pulse-mic {
    0%, 100% { transform: translateY(-50%) scale(1); }
    50% { transform: translateY(-50%) scale(1.15); }
  }
  .snail-walker {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%) scaleX(-1);
    font-size: 1.8rem;
    pointer-events: none;
    z-index: 1;
    transition: opacity 0.2s;
  } */
</style>

<!-- <script>
  (function() {
    var input = document.getElementById('chat-input-new');
    var snail = document.getElementById('snail-new');
    if (!input || !snail) return;

    var snailX = 0;
    var snailDir = 1;
    var walkInterval;

    function maxX() {
      return input.offsetWidth - 40;
    }

    function updateFacing() {
      snail.style.transform = snailDir === 1
        ? 'translateY(-50%) scaleX(-1)'
        : 'translateY(-50%) scaleX(1)';
    }

    function startSnail() {
      walkInterval = setInterval(function() {
        snailX += 0.5 * snailDir;
        if (snailX >= maxX()) { snailX = maxX(); snailDir = -1; updateFacing(); }
        else if (snailX <= 0)  { snailX = 0;      snailDir =  1; updateFacing(); }
        snail.style.left = snailX + 'px';
      }, 50);
    }

    function stopSnail() { clearInterval(walkInterval); }

    startSnail();

    input.addEventListener('focus', function() { snail.style.opacity = '0'; stopSnail(); });
    input.addEventListener('blur',  function() {
      if (!input.value) { snail.style.opacity = '1'; startSnail(); }
    });
    input.addEventListener('input', function() {
      snail.style.opacity = input.value ? '0' : '1';
    });
  })();

  // Voice-to-text
  (function() {
    var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    var btn = document.getElementById('voice-btn');
    var input = document.getElementById('chat-input-new');
    var snail = document.getElementById('snail-new');

    if (!SpeechRecognition || !btn) {
      if (btn) btn.style.display = 'none';
      return;
    }

    var recognition = new SpeechRecognition();
    recognition.continuous = false;
    recognition.interimResults = true;
    recognition.lang = navigator.language || 'en-US';

    var isRecording = false;

    btn.addEventListener('click', function() {
      if (isRecording) {
        recognition.stop();
        return;
      }
      recognition.start();
    });

    recognition.addEventListener('start', function() {
      isRecording = true;
      btn.classList.add('recording');
      btn.querySelector('i').className = 'fa-solid fa-stop';
      if (snail) snail.style.opacity = '0';
      input.focus();
    });

    recognition.addEventListener('result', function(e) {
      var transcript = '';
      for (var i = 0; i < e.results.length; i++) {
        transcript += e.results[i][0].transcript;
      }
      input.value = transcript;
      input.dispatchEvent(new Event('input'));
    });

    recognition.addEventListener('end', function() {
      isRecording = false;
      btn.classList.remove('recording');
      btn.querySelector('i').className = 'fa-solid fa-microphone';
    });

    recognition.addEventListener('error', function() {
      isRecording = false;
      btn.classList.remove('recording');
      btn.querySelector('i').className = 'fa-solid fa-microphone';
    });
  })();
</script>
