<% content_for :head do %>
  <style>
    header { display: none; }
    #main-content { padding: 0; margin: 0; }
  </style>
<% end %>

<div class="landing-page">
  <div class="landing-container">

    <div class="brand-section">
      <div class="brand-wordmark">Snail<span class="brand-r">-R</span></div>
    </div>

    <div class="mascot-wrapper">
      <div class="mascot-ring">
        <div class="mascot-circle">
          <span class="mascot-emoji">🌀</span>
        </div>
      </div>
      <div class="mascot-glow"></div>
    </div>

    <div class="hero-text">
      <h2 class="hero-headline">Master Your Time.</h2>
      <p class="hero-description">
        Snail-R is the mindful productivity app that slows you down to speed you up.
        Plan intentionally, reflect daily, and achieve more — one deliberate step at a time.
      </p>
    </div>

    <div class="feature-pills">
      <span class="pill">⏱ Time Tracking</span>
      <span class="pill">🎯 Focus Goals</span>
      <span class="pill">📊 Insights</span>
    </div>

    <div class="cta-section">
      <%= link_to (user_signed_in? ? objectives_path : new_user_registration_path), class: "btn-cta btn-signup" do %>
        <%= user_signed_in? ? "Get Started" : "Get Started — Sign up Now" %>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      <% end %>

      <% unless user_signed_in? %>
        <%= link_to "Log In", new_user_session_path, class: "btn-cta btn-login" %>
      <% end %>
    </div>

    <p class="footer-note">No credit card required &nbsp;·&nbsp; Free to start</p>

  </div>
</div>
