<% content_for :head do %>
  <style>
    header { display: none; }
    #main-content { padding: 0; margin: 0; }
  </style>
<% end %>

<div class="snail-app-layout">
  <div class="app-container">

    <section class="hero-dashboard">
      <h1 class="headline">Settings.</h1>
      <p class="subheadline">Configure your Snail-R experience.</p>
    </section>

    <!-- Notifications -->
    <section class="settings-section">
      <h3 class="section-label">Notifications</h3>
      <div class="settings-group">
        <div class="settings-row">
          <div class="settings-row-info">
            <span class="settings-row-title">Daily reminders</span>
            <span class="settings-row-desc">Get a daily nudge to review your objectives</span>
          </div>
          <span class="settings-badge-soon">Coming soon</span>
        </div>
        <div class="settings-row">
          <div class="settings-row-info">
            <span class="settings-row-title">Step completion alerts</span>
            <span class="settings-row-desc">Be notified when a step is marked as done</span>
          </div>
          <span class="settings-badge-soon">Coming soon</span>
        </div>
      </div>
    </section>

    <!-- Appearance -->
    <section class="settings-section">
      <h3 class="section-label">Appearance</h3>
      <div class="settings-group">
        <div class="settings-row">
          <div class="settings-row-info">
            <span class="settings-row-title">Dark mode</span>
            <span class="settings-row-desc">Switch to a darker interface</span>
          </div>
          <span class="settings-badge-soon">Coming soon</span>
        </div>
        <div class="settings-row">
          <div class="settings-row-info">
            <span class="settings-row-title">Accent color</span>
            <span class="settings-row-desc">Customize the highlight color</span>
          </div>
          <span class="settings-badge-soon">Coming soon</span>
        </div>
      </div>
    </section>

    <!-- Data -->
    <section class="settings-section">
      <h3 class="section-label">Data & Privacy</h3>
      <div class="settings-group">
        <div class="settings-row">
          <div class="settings-row-info">
            <span class="settings-row-title">Export my data</span>
            <span class="settings-row-desc">Download all your objectives and steps</span>
          </div>
          <span class="settings-badge-soon">Coming soon</span>
        </div>
        <div class="settings-row settings-row-danger">
          <div class="settings-row-info">
            <span class="settings-row-title">Delete my account</span>
            <span class="settings-row-desc">Permanently remove your account and all data</span>
          </div>
          <span class="settings-badge-soon">Coming soon</span>
        </div>
      </div>
    </section>

  </div>
</div>
