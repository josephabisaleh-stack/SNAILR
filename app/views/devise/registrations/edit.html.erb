<% content_for :head do %>
  <style>
    header { display: none; }
    #main-content { padding: 0; margin: 0; }
  </style>
<% end %>

<div class="snail-app-layout">
  <div class="app-container">

    <section class="hero-dashboard">
      <h1 class="headline">Your Profile.</h1>
      <p class="subheadline">Manage your personal information.</p>
    </section>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.error_notification %>

      <h3 class="section-label">Personal Info</h3>

      <%= f.input :first_name, label: "First Name", required: false,
            input_html: { autocomplete: "given-name" } %>
      <%= f.input :last_name, label: "Last Name", required: false,
            input_html: { autocomplete: "family-name" } %>
      <%= f.input :display_name, label: "Display Name", required: false %>
      <%= f.input :email, label: "Email", required: true,
            input_html: { autocomplete: "email" } %>

      <h3 class="section-label" style="margin-top: 32px;">Change Password</h3>

      <%= f.input :password, label: "New Password",
            hint: "Leave blank to keep your current password",
            required: false,
            input_html: { autocomplete: "new-password" } %>
      <%= f.input :password_confirmation, label: "Confirm New Password",
            required: false,
            input_html: { autocomplete: "new-password" } %>
      <%= f.input :current_password, label: "Current Password",
            hint: "Required to save any changes",
            required: true,
            input_html: { autocomplete: "current-password" } %>

      <footer class="app-footer">
        <%= f.button :submit, "Save Changes", class: "btn-pill btn-primary w-100" %>
      </footer>
    <% end %>

  </div>
</div>
