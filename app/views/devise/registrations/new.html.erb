<% content_for :head do %>
  <style>
    header { display: none; }
    #main-content { padding: 0; margin: 0; }
  </style>
<% end %>

<div class="auth-page">
  <div class="auth-container">

    <%= link_to root_path, class: "auth-back" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Back
    <% end %>

    <div class="auth-brand">
      <div class="auth-brand-wordmark">Snail<span>-R</span></div>
      <p class="auth-brand-sub">Master Your Time</p>
    </div>

    <div class="auth-card">
      <h1 class="auth-title">Create your account.</h1>
      <p class="auth-subtitle">Start mastering your time today.</p>

      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= f.error_notification %>

        <div class="auth-fields">
          <div class="auth-field-row">
            <%= f.input :first_name,
                        required: true,
                        label: "First Name",
                        input_html: { autocomplete: "given-name", class: "auth-input", placeholder: "Jane" },
                        wrapper_html: { class: "auth-field" } %>

            <%= f.input :last_name,
                        required: true,
                        label: "Last Name",
                        input_html: { autocomplete: "family-name", class: "auth-input", placeholder: "Doe" },
                        wrapper_html: { class: "auth-field" } %>
          </div>

          <%= f.input :email,
                      required: true,
                      label: "Email",
                      input_html: { autocomplete: "email", class: "auth-input", placeholder: "you@example.com" },
                      wrapper_html: { class: "auth-field" } %>

          <%= f.input :password,
                      required: true,
                      label: "Password",
                      hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                      input_html: { autocomplete: "new-password", class: "auth-input", placeholder: "••••••••" },
                      wrapper_html: { class: "auth-field" } %>

          <%= f.input :password_confirmation,
                      required: true,
                      label: "Confirm Password",
                      input_html: { autocomplete: "new-password", class: "auth-input", placeholder: "••••••••" },
                      wrapper_html: { class: "auth-field" } %>
        </div>

        <%= f.button :submit, "Get Started", class: "btn-auth btn-auth-primary" %>
      <% end %>
    </div>

    <div class="auth-footer-links">
      <span class="auth-footer-text">Already have an account?</span>
      <%= link_to "Log In", new_session_path(resource_name), class: "auth-link auth-link-emphasis" %>
    </div>

  </div>
</div>
