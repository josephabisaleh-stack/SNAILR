<% content_for :head do %>
  <style>
    header { display: none; }
    #main-content { padding: 0; margin: 0; }
  </style>
<% end %>

<div class="auth-page">
  <div class="auth-container">

    <%= link_to root_path, class: "auth-back" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Back
    <% end %>

    <div class="auth-brand">
      <div class="auth-brand-wordmark">Snail<span>-R</span></div>
      <p class="auth-brand-sub">Master Your Time</p>
    </div>

    <div class="auth-card">
      <h1 class="auth-title">Welcome back.</h1>
      <p class="auth-subtitle">Sign in to continue your journey.</p>

      <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="auth-fields">
          <%= f.input :email,
                      required: false,
                      autofocus: true,
                      label: "Email",
                      input_html: { autocomplete: "email", class: "auth-input", placeholder: "you@example.com" },
                      wrapper_html: { class: "auth-field" } %>

          <%= f.input :password,
                      required: false,
                      label: "Password",
                      input_html: { autocomplete: "current-password", class: "auth-input", placeholder: "••••••••" },
                      wrapper_html: { class: "auth-field" } %>

          <% if devise_mapping.rememberable? %>
            <%= f.input :remember_me, as: :boolean, wrapper_html: { class: "auth-remember" } %>
          <% end %>
        </div>

        <%= f.button :submit, "Log In", class: "btn-auth btn-auth-primary" %>
      <% end %>
    </div>

    <div class="auth-footer-links">
      <% if devise_mapping.recoverable? %>
        <%= link_to "Forgot your password?", new_password_path(resource_name), class: "auth-link" %>
      <% end %>
      <span class="auth-divider">·</span>
      <%= link_to "Create an account", new_registration_path(resource_name), class: "auth-link auth-link-emphasis" %>
    </div>

  </div>
</div>
